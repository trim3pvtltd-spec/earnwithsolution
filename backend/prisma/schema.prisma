// ============================================================================
// EARNING WITH SOLUTION — DATABASE SCHEMA
// Tri M3 Credible Solution Pvt Ltd
// ============================================================================
// This schema is the single source of truth for the entire platform:
// Android App, iOS App, Website, Admin Panel, Super Admin Dashboard.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  CUSTOMER
  FOS // Field Executive / Sales Agent
  SHOPKEEPER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  PENDING_KYC
  ACTIVE
  BLOCKED
  SUSPENDED
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum ProductCategory {
  BANK_ACCOUNT
  DEMAT_ACCOUNT
  PREPAID_CARD
  CREDIT_CARD
  LOAN
  INSURANCE
  FASTAG
  RECHARGE
  BILL_PAYMENT
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  COMING_SOON
}

enum LeadStatus {
  PENDING
  IN_PROCESS
  APPROVED
  REJECTED
  DUPLICATE
}

enum LeadSourceType {
  SELF
  FOS
  SHOPKEEPER
}

enum WalletTxnType {
  CREDIT
  DEBIT
  WITHDRAWAL
  BONUS
  REFERRAL
}

enum WalletTxnStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
}

enum WithdrawalMode {
  UPI
  BANK
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum BcStatus {
  PENDING
  VERIFIED
  APPROVED
  REJECTED
}

enum NotificationCategory {
  NEW_OFFERS
  PAYOUT_UPDATES
  WITHDRAW_UPDATES
  TRAINING
  ANNOUNCEMENTS
  FESTIVAL_OFFERS
  BANK_OFFERS
  SECURITY_ALERT
  GENERAL
}

enum NotificationChannel {
  PUSH
  SMS
  WHATSAPP
  EMAIL
}

enum NotificationDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  READ
}

enum LogType {
  ACTIVITY
  ADMIN
  AUDIT
}

enum FraudFlagType {
  DUPLICATE_MOBILE
  DUPLICATE_PAN
  DUPLICATE_AADHAAR
  PATTERN_ANOMALY
  GPS_ANOMALY
  DEVICE_ANOMALY
}

enum FraudFlagStatus {
  PENDING_REVIEW
  REVIEWED_SAFE
  CONFIRMED_FRAUD
}

// ============================================================================
// USERS & AUTH
// ============================================================================

model User {
  id                String     @id @default(uuid())
  fullName          String
  mobile            String     @unique
  email             String?
  role              UserRole   @default(CUSTOMER)
  status            UserStatus @default(PENDING_KYC)

  // Referral
  referralCode      String     @unique // this user's own code to share
  referredByCode    String? // code used at signup
  referredById      String?
  referredBy        User?      @relation("Referrals", fields: [referredById], references: [id])
  referrals         User[]     @relation("Referrals")

  // Hierarchy (Shopkeeper -> FOS)
  parentShopkeeperId String?
  parentShopkeeper   User?     @relation("ShopkeeperTeam", fields: [parentShopkeeperId], references: [id])
  teamMembers        User[]    @relation("ShopkeeperTeam")

  // Preferences
  language          String     @default("en") // en | hi | hinglish
  darkMode          Boolean    @default(false)
  biometricEnabled  Boolean    @default(false)

  // KYC
  kycStatus         KycStatus  @default(NOT_SUBMITTED)
  aadhaarNumberHash String?    // hashed for duplicate detection
  aadhaarNumberEnc  String?    // AES-256 encrypted actual value
  panNumberHash     String?
  panNumberEnc      String?
  photoUrl          String?
  addressProofUrl   String?

  // Bank details (for payout) - encrypted
  bankAccountNumberEnc String?
  bankIfsc              String?
  bankName               String?
  upiId                  String?

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  wallet            Wallet?
  leadsAsExecutive  Lead[]           @relation("ExecutiveLeads")
  leadsAsCustomer   Lead[]           @relation("CustomerLeads")
  withdrawalRequests WithdrawalRequest[]
  bcApplications    BcApplication[]
  devices           UserDevice[]
  notifications     NotificationLog[]
  notifPreferences  NotificationPreference[]
  securityLogs      SecurityLog[]
  fraudFlags        FraudFlag[]
  supportTickets    SupportTicket[]
  trainingProgress  TrainingProgress[]
  adminActions      AdminActionLog[] @relation("AdminActor")

  @@index([role])
  @@index([status])
  @@index([parentShopkeeperId])
}

model UserDevice {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  deviceId      String
  deviceModel   String?
  os            String?
  appVersion    String?
  fcmToken      String?
  lastIp        String?
  lastLoginAt   DateTime @default(now())
  isActive      Boolean  @default(true)

  @@index([userId])
}

// ============================================================================
// PRODUCTS (Banking, Loans, Insurance, etc.)
// ============================================================================

model Product {
  id              String          @id @default(uuid())
  title           String
  category        ProductCategory
  subCategory     String? // e.g. "Personal Loan", "Term Life"
  imageUrl        String?
  shortDescription String?
  description     String?
  payoutAmount    Decimal?        @db.Decimal(10, 2) // fixed payout
  payoutPercent   Decimal?        @db.Decimal(5, 2)  // % based payout (loans)
  eligibility     String?
  documentsRequired String[]      @default([])
  affiliateLink   String // EDITABLE ANYTIME by Admin — never hardcoded in app
  trainingVideoUrl String?
  faqs            Json?           // [{question, answer}]
  terms           String?
  status          ProductStatus   @default(ACTIVE)
  displayOrder    Int             @default(0)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  leads           Lead[]
  linkHistory     AffiliateLinkHistory[]

  @@index([category])
  @@index([status])
}

model AffiliateLinkHistory {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  oldLink     String
  newLink     String
  changedById String
  changedAt   DateTime @default(now())

  @@index([productId])
}

// ============================================================================
// LEADS (Company Lead Form -> Affiliate Redirect)
// ============================================================================

model Lead {
  id                String         @id @default(uuid())
  leadCode          String         @unique // EWS-LD-YYYY-NNNNNN

  // Customer details captured in the form
  customerName      String
  mobile            String
  altMobile         String?
  email              String?
  state              String
  district           String
  city                String
  pincode             String
  occupation          String
  monthlyIncome       String

  // Linked customer account (optional — if applying via own account)
  customerId          String?
  customer             User?    @relation("CustomerLeads", fields: [customerId], references: [id])

  // Product
  productId            String
  product               Product   @relation(fields: [productId], references: [id])

  // Executive who sourced the lead
  executiveId           String?
  executive              User?    @relation("ExecutiveLeads", fields: [executiveId], references: [id])
  executiveNameSnapshot  String?
  sourceType             LeadSourceType @default(SELF)

  // Auto-captured metadata
  gpsLat                 Decimal? @db.Decimal(10, 7)
  gpsLng                  Decimal? @db.Decimal(10, 7)
  deviceInfo              Json?
  ipAddress               String?

  // Status
  status                  LeadStatus @default(PENDING)
  statusReason             String?
  duplicateOfLeadId        String?

  affiliateRedirectStatus  String?  // success | failed
  consentGiven              Boolean @default(false)

  walletCredited            Boolean @default(false)
  walletTxnId                String?

  statusUpdatedById          String?
  statusUpdatedAt            DateTime?

  submittedAt                 DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  statusHistory                LeadStatusHistory[]

  @@index([status])
  @@index([mobile])
  @@index([productId])
  @@index([executiveId])
  @@index([state, city])
}

model LeadStatusHistory {
  id          String     @id @default(uuid())
  leadId      String
  lead        Lead       @relation(fields: [leadId], references: [id])
  oldStatus   LeadStatus?
  newStatus   LeadStatus
  changedById String?
  reason      String?
  changedAt   DateTime   @default(now())

  @@index([leadId])
}

// ============================================================================
// WALLET
// ============================================================================

model Wallet {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  balance           Decimal  @default(0) @db.Decimal(12, 2)
  lifetimeEarnings  Decimal  @default(0) @db.Decimal(12, 2)
  pendingEarnings   Decimal  @default(0) @db.Decimal(12, 2)
  approvedEarnings  Decimal  @default(0) @db.Decimal(12, 2)
  rejectedEarnings  Decimal  @default(0) @db.Decimal(12, 2)
  bonusTotal        Decimal  @default(0) @db.Decimal(12, 2)
  referralIncomeTotal Decimal @default(0) @db.Decimal(12, 2)
  updatedAt         DateTime @updatedAt

  transactions      WalletTransaction[]
}

model WalletTransaction {
  id               String          @id @default(uuid())
  txnCode          String          @unique
  walletId         String
  wallet           Wallet          @relation(fields: [walletId], references: [id])
  type             WalletTxnType
  productId        String?
  leadId           String?
  amount           Decimal         @db.Decimal(12, 2)
  status           WalletTxnStatus @default(PENDING)
  rejectionReason  String?
  description      String?
  createdAt        DateTime        @default(now())

  @@index([walletId])
  @@index([type])
}

model WithdrawalRequest {
  id               String            @id @default(uuid())
  withdrawalCode   String            @unique // EWS-WD-YYYY-NNNNNN
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  amount           Decimal           @db.Decimal(12, 2)
  mode             WithdrawalMode
  upiId            String?
  bankName         String?
  accountNumberEnc String?
  ifsc             String?
  remarks          String?
  status           WithdrawalStatus  @default(PENDING)
  rejectionReason  String?
  utrReference     String?
  processedById    String?
  requestedAt      DateTime          @default(now())
  processedAt      DateTime?
  completedAt      DateTime?

  @@index([userId])
  @@index([status])
}

// ============================================================================
// BANKING BC (Business Correspondent)
// ============================================================================

model Bank {
  id       String @id @default(uuid())
  name     String @unique
  logoUrl  String?
  status   String @default("active")

  bcApplications BcApplication[]
}

model BcApplication {
  id                  String    @id @default(uuid())
  applicationCode     String    @unique // EWS-BC-YYYY-NNNNNN
  executiveId         String
  executive            User     @relation(fields: [executiveId], references: [id])
  bankId               String
  bank                  Bank    @relation(fields: [bankId], references: [id])

  aadhaarDocUrl         String
  panDocUrl              String
  photoUrl                String
  cancelledChequeUrl      String
  addressProofUrl          String

  status                    BcStatus @default(PENDING)
  rejectionReason           String?
  bcIdNumber                 String?
  verifiedById                String?
  approvedById                 String?

  submittedAt                   DateTime @default(now())
  verifiedAt                     DateTime?
  approvedAt                      DateTime?

  statusHistory                    BcStatusHistory[]

  @@index([executiveId])
  @@index([status])
}

model BcStatusHistory {
  id              String        @id @default(uuid())
  applicationId    String
  application       BcApplication @relation(fields: [applicationId], references: [id])
  oldStatus         BcStatus?
  newStatus          BcStatus
  changedById         String?
  reason               String?
  changedAt             DateTime @default(now())

  @@index([applicationId])
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model NotificationTemplate {
  id               String                @id @default(uuid())
  category         NotificationCategory
  channels         NotificationChannel[]
  title            String
  body             String
  whatsappTemplateId String?
  status           String                @default("active")
  createdAt        DateTime              @default(now())

  logs             NotificationLog[]
}

model NotificationLog {
  id            String                      @id @default(uuid())
  templateId    String?
  template      NotificationTemplate?       @relation(fields: [templateId], references: [id])
  userId        String
  user           User                       @relation(fields: [userId], references: [id])
  channel        NotificationChannel
  title           String
  content          String
  status            NotificationDeliveryStatus @default(QUEUED)
  triggeredBy       String? // "system" or admin userId
  sentAt             DateTime                @default(now())

  @@index([userId])
  @@index([channel])
}

model NotificationPreference {
  id             String               @id @default(uuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id])
  category       NotificationCategory
  pushEnabled    Boolean              @default(true)
  smsEnabled     Boolean              @default(true)
  whatsappEnabled Boolean             @default(true)
  emailEnabled    Boolean             @default(true)

  @@unique([userId, category])
}

// ============================================================================
// BANNERS / OFFERS / TRAINING / SUPPORT / ANNOUNCEMENTS
// ============================================================================

model Banner {
  id           String   @id @default(uuid())
  imageUrl     String
  title        String?
  deepLink     String?
  targetRole   UserRole?
  displayOrder Int      @default(0)
  startDate    DateTime?
  endDate      DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model TrainingVideo {
  id          String   @id @default(uuid())
  title       String
  description String?
  videoUrl    String
  thumbnailUrl String?
  productId   String?
  category    String?
  durationSeconds Int?
  createdAt   DateTime @default(now())

  progress    TrainingProgress[]
}

model TrainingProgress {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  trainingVideoId String
  trainingVideo   TrainingVideo @relation(fields: [trainingVideoId], references: [id])
  watchedSeconds  Int           @default(0)
  completed       Boolean       @default(false)
  updatedAt       DateTime      @updatedAt

  @@unique([userId, trainingVideoId])
}

model SupportTicket {
  id         String   @id @default(uuid())
  ticketCode String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  subject    String
  message    String
  status     String   @default("open") // open | in_progress | resolved
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  replies    SupportReply[]
}

model SupportReply {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  repliedById String
  isAdmin   Boolean       @default(false)
  message   String
  createdAt DateTime      @default(now())

  @@index([ticketId])
}

// ============================================================================
// LOCATIONS
// ============================================================================

model State {
  id       String   @id @default(uuid())
  name     String   @unique
  isActive Boolean  @default(true)
  cities   City[]
}

model City {
  id       String  @id @default(uuid())
  name     String
  stateId  String
  state    State   @relation(fields: [stateId], references: [id])
  pincode  String?
  isActive Boolean @default(true)

  @@index([stateId])
}

// ============================================================================
// ADMIN / RBAC
// ============================================================================

model AdminRole {
  id          String   @id @default(uuid())
  name        String   @unique // e.g. "Finance Admin", "Support Admin"
  permissions Json     // { module: ["view","edit","approve"] }
  createdAt   DateTime @default(now())
}

model AdminActionLog {
  id        String   @id @default(uuid())
  actorId   String
  actor     User     @relation("AdminActor", fields: [actorId], references: [id])
  module    String   // e.g. "leads", "withdrawals", "products"
  action    String   // e.g. "approved_lead", "edited_affiliate_link"
  targetId  String?
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([module])
}

// ============================================================================
// SECURITY / LOGS / FRAUD
// ============================================================================

model SecurityLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  logType   LogType
  action    String
  ipAddress String?
  deviceInfo Json?
  gpsLat    Decimal? @db.Decimal(10, 7)
  gpsLng    Decimal? @db.Decimal(10, 7)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([logType])
}

model FraudFlag {
  id         String           @id @default(uuid())
  userId     String?
  user       User?            @relation(fields: [userId], references: [id])
  leadId     String?
  flagType   FraudFlagType
  riskScore  Int              @default(0)
  status     FraudFlagStatus  @default(PENDING_REVIEW)
  reviewedById String?
  createdAt  DateTime         @default(now())

  @@index([status])
}

model AppSettings {
  id                    String   @id @default(uuid())
  minWithdrawalAmount   Decimal  @default(500) @db.Decimal(10, 2)
  referralBonusPercent  Decimal  @default(5) @db.Decimal(5, 2)
  maintenanceMode       Boolean  @default(false)
  minAppVersionAndroid  String?
  minAppVersionIos      String?
  updatedAt             DateTime @updatedAt
}
